# Copy to .env and adjust. Never commit .env.

# Postgres (matches docker-compose.yml defaults)
DATABASE_URL=postgresql+asyncpg://pokedex:pokedex@localhost:5432/pokedex_tcg

# Redis (reserved for caching; not required for phase 1 features)
REDIS_URL=redis://localhost:6379/0

# JWT — generate a real secret: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=change-me
JWT_ACCESS_TTL_MINUTES=30
JWT_REFRESH_TTL_DAYS=14

# Pokémon TCG API (https://dev.pokemontcg.io — free key raises rate limits; optional)
POKEMONTCG_API_KEY=
